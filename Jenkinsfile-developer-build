            }
        }

        stage('Resolve Image Tags') {
            steps {
                script {
                    def summary = []
                    services.each { svc ->
                        def branch = normalizeBranch(params[svc.branchParam])
                        validateBranch(branch)
                        def imageTag = resolveBranchCommitId(branch)
                        def repository = "${params.DOCKERHUB_ORG}/${svc.repository}"
                        env."${svc.key}_RESOLVED_BRANCH" = branch
                        env."${svc.key}_IMAGE_TAG" = imageTag
                        env."${svc.key}_IMAGE_REPOSITORY" = repository

                        summary << "${svc.chart.padRight(18)} branch=${branch.padRight(25)} tag=${imageTag}"
                    }

