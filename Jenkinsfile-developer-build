        string(name: 'SAMPLEDATA_BRANCH', defaultValue: 'main', description: 'Branch to deploy for sampledata')
        string(name: 'DOCKERHUB_ORG', defaultValue: '23120022', description: 'Docker Hub organization or username for images')
        string(name: 'DEFAULT_SERVICE_TAG', defaultValue: 'main', description: 'Default tag for services using main branch')
