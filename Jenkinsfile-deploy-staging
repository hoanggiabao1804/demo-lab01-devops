def IMAGE_TAG = ''

pipeline{
    agent {
        docker {
            image '23120022/zakirepo:release-builder-v1.0'
            registryUrl 'https://index.docker.io/v1/'
            registryCredentialsId 'dockerhub_cred'
            args '''
            -u root 
            -v /var/run/docker.sock:/var/run/docker.sock
            -v $HOME/.npm:/root/.npm
            -v $HOME/.m2:/root/.m2
            '''
        }
    }
    options {
        skipDefaultCheckout(true)
    }
    stages{
        stage('Checkout'){
            steps{
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: scm.userRemoteConfigs
                ])
                sh 'git fetch --tags --force origin "+refs/tags/*:refs/tags/*"'
            }
        }
        stage('Init') {
            steps {
                script {
                    sh '''
                        git config --global --add safe.directory '*'
                    '''

                    def gitRef = env.TAG_NAME ?: env.ref ?: env.REF ?: env.GIT_BRANCH ?: env.BRANCH_NAME ?: ''
                    if (env.TAG_NAME || gitRef ==~ /^refs\/tags\/.+/) {
                        IMAGE_TAG = gitRef.replaceFirst(/^origin\//, '').replaceFirst(/^refs\/tags\//, '')
                    } else {
                        IMAGE_TAG = sh(
                            script: '''
                                git tag --merged origin/main --list 'v[0-9]*' --sort=-v:refname |
                                head -n 1
                            ''',
                            returnStdout: true
                        ).trim()
                    }

                    if (IMAGE_TAG == '') {
                        error 'Cannot resolve latest release tag. Create a tag like v1.2.3 on main first.'
                    }

                    if (!(IMAGE_TAG ==~ /^v\\d+\\.\\d+\\.\\d+$/)) {
                        error "Invalid staging release tag '${IMAGE_TAG}'. Expected format: v1.2.3"
                    }

                    sh "git checkout -f ${IMAGE_TAG}"
                    echo "Current tag name is: '$IMAGE_TAG'"
                }
            }
        }
        stage('Dockerhub Login') {
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub_cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''#!/usr/bin/env bash
                        set -e
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }
            }
        }
        stage('Build and Push Docker Images'){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub_cred',
                    usernameVariable: 'DOCKER_USER', 
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    script{
                        services.each { svc ->
                            def repository = "${env.DOCKER_USER}/yas-${svc.name}"

                            if (svc.type == 'backend') {
                                sh """
                                    eval "${svc.build}"
                                """
                            }

                            sh """
                                docker build -t $repository:$IMAGE_TAG ./${svc.path}
                                docker push $repository:$IMAGE_TAG
                            """
                        }
                    }
                }
            }
        }
        stage('Checkout to YAS manifest repository') {
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'github_cred',
                    usernameVariable: 'GITHUB_USER',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh """
                        [ -d "yas-helmchart-k8s" ] && rm -rf yas-helmchart-k8s/
                        git clone https://\$GITHUB_USER:\$GITHUB_TOKEN@github.com/hoanggiabao1804/yas-helmchart-k8s.git
                    """
                }
            }
        }
        stage('Apply Deployments'){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub_cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    script {
                        dir('yas-helmchart-k8s') {
                            sh """
                                git config --global user.name "Jenkins CI"
                                git config --global user.email "jenkins@example.com"
                                git checkout main
                            """

                            echo "Updating Deployment..."

                            services.each { svc ->
                                def repository = "${env.DOCKER_USER}/yas-${svc.name}"

                                sh """
                                    yq -i '
                                    .${svc.type}.image.repository = "${repository}" |
                                    .${svc.type}.image.tag = "$IMAGE_TAG"
                                    ' staging/${svc.chart}-values.yaml

                                    git add staging/${svc.chart}-values.yaml
                                """
                            }

                            sh """
                                git commit -m "release(${IMAGE_TAG}): Update staging manifest files of services: ${services*.name.collect().join("|")}."
                                git push origin main
                            """    
                        }

                    }
                }
            }
        }
    }
    post {
        always {
            sh '''#!/usr/bin/env bash
                set +e

                if [ "$(id -u)" = "0" ] && [ -n "${WORKSPACE:-}" ]; then
                    workspace_owner="$(stat -c '%u:%g' "$WORKSPACE" 2>/dev/null)"

                    if [ -n "$workspace_owner" ] && [ "$workspace_owner" != "0:0" ]; then
                        chown -R "$workspace_owner" "$WORKSPACE"

                        if [ -d "${WORKSPACE}@tmp" ]; then
                            chown -R "$workspace_owner" "${WORKSPACE}@tmp"
                        fi
                    fi
                fi
            '''
        }
    }
}
