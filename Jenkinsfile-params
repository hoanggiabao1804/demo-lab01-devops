def services = [
    [key: 'BACKOFFICE_BFF',    repository: 'yas-backoffice-bff',    chart: 'backoffice-bff',    branchParam: 'BACKOFFICE_BFF_BRANCH'],
    [key: 'BACKOFFICE_UI',     repository: 'yas-backoffice',        chart: 'backoffice-ui',     branchParam: 'BACKOFFICE_UI_BRANCH'],
    [key: 'STOREFRONT_BFF',    repository: 'yas-storefront-bff',    chart: 'storefront-bff',    branchParam: 'STOREFRONT_BFF_BRANCH'],
    [key: 'STOREFRONT_UI',     repository: 'yas-storefront',        chart: 'storefront-ui',     branchParam: 'STOREFRONT_UI_BRANCH'],

    [key: 'CART',              repository: 'yas-cart',              chart: 'cart',              branchParam: 'CART_BRANCH'],
    [key: 'CUSTOMER',          repository: 'yas-customer',          chart: 'customer',          branchParam: 'CUSTOMER_BRANCH'],
    [key: 'INVENTORY',         repository: 'yas-inventory',         chart: 'inventory',         branchParam: 'INVENTORY_BRANCH'],
    [key: 'LOCATION',          repository: 'yas-location',          chart: 'location',          branchParam: 'LOCATION_BRANCH'],
    [key: 'MEDIA',             repository: 'yas-media',             chart: 'media',             branchParam: 'MEDIA_BRANCH'],
    [key: 'ORDER',             repository: 'yas-order',             chart: 'order',             branchParam: 'ORDER_BRANCH'],
    [key: 'PAYMENT',           repository: 'yas-payment',           chart: 'payment',           branchParam: 'PAYMENT_BRANCH'],
    [key: 'PAYMENT_PAYPAL',    repository: 'yas-payment-paypal',    chart: 'payment-paypal',    branchParam: 'PAYMENT_PAYPAL_BRANCH'],
    [key: 'PRODUCT',           repository: 'yas-product',           chart: 'product',           branchParam: 'PRODUCT_BRANCH'],
    [key: 'PROMOTION',         repository: 'yas-promotion',         chart: 'promotion',         branchParam: 'PROMOTION_BRANCH'],
    [key: 'RATING',            repository: 'yas-rating',            chart: 'rating',            branchParam: 'RATING_BRANCH'],
    [key: 'RECOMMENDATION',    repository: 'yas-recommendation',    chart: 'recommendation',    branchParam: 'RECOMMENDATION_BRANCH'],
    [key: 'SEARCH',            repository: 'yas-search',            chart: 'search',            branchParam: 'SEARCH_BRANCH'],
    [key: 'TAX',               repository: 'yas-tax',               chart: 'tax',               branchParam: 'TAX_BRANCH'],
    [key: 'WEBHOOK',           repository: 'yas-webhook',           chart: 'webhook',           branchParam: 'WEBHOOK_BRANCH'],
    [key: 'SAMPLEDATA',        repository: 'yas-sampledata',        chart: 'sampledata',        branchParam: 'SAMPLEDATA_BRANCH']
]

def NAMESPACE = 'yas'

def normalizeBranch = { rawBranch ->
    def branch = rawBranch == null ? '' : rawBranch.trim()
    if (branch == '') {
        return 'main'
    }
    branch = branch.replaceFirst(/^origin\//, '')
    branch = branch.replaceFirst(/^refs\/heads\//, '')
    return branch
}

def validateBranch = { branch ->
    if (!(branch ==~ /^[A-Za-z0-9._\/-]+$/)) {
        error "Invalid branch name: ${branch}"
    }
}

def resolveBranchCommitId = { branch ->
    if (branch == 'main') {
        return params.DEFAULT_SERVICE_TAG ?: 'main'
    }

    def sha = sh(script: "git ls-remote --heads origin refs/heads/${branch} | cut -f1", returnStdout: true).trim()
    if (sha == '') {
        error "Branch not found on remote origin: ${branch}"
    }
    return sha.take(7)
}

pipeline {
    agent any

    parameters {
        string(name: 'BACKOFFICE_BFF_BRANCH', defaultValue: 'main', description: 'Branch to deploy for backoffice-bff')
        string(name: 'BACKOFFICE_UI_BRANCH', defaultValue: 'main', description: 'Branch to deploy for backoffice-ui')
        string(name: 'STOREFRONT_BFF_BRANCH', defaultValue: 'main', description: 'Branch to deploy for storefront-bff')
        string(name: 'STOREFRONT_UI_BRANCH', defaultValue: 'main', description: 'Branch to deploy for storefront-ui')
        string(name: 'CART_BRANCH', defaultValue: 'main', description: 'Branch to deploy for cart')
        string(name: 'CUSTOMER_BRANCH', defaultValue: 'main', description: 'Branch to deploy for customer')
        string(name: 'INVENTORY_BRANCH', defaultValue: 'main', description: 'Branch to deploy for inventory')
        string(name: 'LOCATION_BRANCH', defaultValue: 'main', description: 'Branch to deploy for location')
        string(name: 'MEDIA_BRANCH', defaultValue: 'main', description: 'Branch to deploy for media')
        string(name: 'ORDER_BRANCH', defaultValue: 'main', description: 'Branch to deploy for order')
        string(name: 'PAYMENT_BRANCH', defaultValue: 'main', description: 'Branch to deploy for payment')
        string(name: 'PAYMENT_PAYPAL_BRANCH', defaultValue: 'main', description: 'Branch to deploy for payment-paypal')
        string(name: 'PRODUCT_BRANCH', defaultValue: 'main', description: 'Branch to deploy for product')
        string(name: 'PROMOTION_BRANCH', defaultValue: 'main', description: 'Branch to deploy for promotion')
        string(name: 'RATING_BRANCH', defaultValue: 'main', description: 'Branch to deploy for rating')
        string(name: 'RECOMMENDATION_BRANCH', defaultValue: 'main', description: 'Branch to deploy for recommendation')
        string(name: 'SEARCH_BRANCH', defaultValue: 'main', description: 'Branch to deploy for search')
        string(name: 'TAX_BRANCH', defaultValue: 'main', description: 'Branch to deploy for tax')
        string(name: 'WEBHOOK_BRANCH', defaultValue: 'main', description: 'Branch to deploy for webhook')
        string(name: 'SAMPLEDATA_BRANCH', defaultValue: 'main', description: 'Branch to deploy for sampledata')
        string(name: 'DOCKERHUB_ORG', defaultValue: '23120022', description: 'Docker Hub organization or username for images')
        string(name: 'DEFAULT_SERVICE_TAG', defaultValue: 'main', description: 'Default tag for services using main branch')
    }

    environment {
        NAMESPACE = "${NAMESPACE}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git fetch --all --tags --prune'
            }
        }

        stage('Check CD Agent') {
            steps {
                sh '''
                    set -e
                    helm version
                    yq --version
                    kubectl version --client
                    docker version
                '''
            }
        }

        stage('Resolve Image Tags') {
            steps {
                script {
                    def summary = []
                    services.each { svc ->
                        def branch = normalizeBranch(params["${svc.key}_BRANCH"])
                        validateBranch(branch)
                        def imageTag = resolveBranchCommitId(branch)
                        def repository = "${params.DOCKERHUB_ORG}/${svc.repository}"

                        env["${svc.key}_RESOLVED_BRANCH"] = branch
                        env["${svc.key}_IMAGE_TAG"] = imageTag
                        env["${svc.key}_IMAGE_REPOSITORY"] = repository

                        summary << "${svc.chart.padRight(18)} branch=${branch.padRight(25)} tag=${imageTag}"
                    }

                    echo "===== Resolved Image Tags ====="
                    echo summary.join('\n')
                }
            }
        }

        stage('Build and Push Docker Images') {
            steps {
                script {
                    def changedServices = services.findAll { svc -> env["${svc.key}_RESOLVED_BRANCH"] != 'main' }
                    if (changedServices.isEmpty()) {
                        echo 'No non-main branch services to build. Using default tags for all services.'
                        return
                    }

                    withCredentials([
                        usernamePassword(
                            credentialsId: 'dockerhub_cred',
                            usernameVariable: 'DOCKER_USER', 
                            passwordVariable: 'DOCKER_PASS'
                            )
                    ]) {
                        sh '''#!/usr/bin/env bash
                        set -e
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        '''
                        changedServices.each { svc ->
                            def branch = env["${svc.key}_RESOLVED_BRANCH"]
                            def imageTag = env["${svc.key}_IMAGE_TAG"]
                            def repository = env["${svc.key}_IMAGE_REPOSITORY"]
                            def servicePath = svc.path

                            echo "Building and pushing ${svc.chart} for branch ${branch} as ${repository}:${imageTag}"

                            sh """#!/usr/bin/env bash
                                set -e
                                BRANCH=\"${branch}\"
                                REPO=\"${repository}\"
                                TAG=\"${imageTag}\"
                                SERVICE_PATH=\"${servicePath}\"

                                git fetch origin \"${branch}\" --no-tags || true
                                tmpdir=\$(mktemp -d)
                                git archive \"origin/${branch}\" | tar -x -C \"\$tmpdir\"
                                docker build -t \"\$REPO:\$TAG\" \"\$tmpdir/\$SERVICE_PATH\"
                                docker push \"\$REPO:\$TAG\"
                                rm -rf \"\$tmpdir\"
                            """
                        }
                    }
                }
            }
        }

        stage('Deploy YAS Configuration') {
            steps {
                dir('k8s/deploy') {
                    sh '''
                        set -e
                        chmod a+x ./deploy-yas-configuration.sh
                        ./deploy-yas-configuration.sh
                    '''
                }
            }
        }

        stage('Deploy Services') {
            steps {
                dir('k8s/deploy') {
                    script {
                        services.each { svc ->
                            def repository = env["${svc.key}_IMAGE_REPOSITORY"]
                            def imageTag = env["${svc.key}_IMAGE_TAG"]
                            def imagePath = svc.imageType == 'ui' ? 'ui.image' : 'backend.image'

                            echo "Deploying ${svc.chart} with image ${repository}:${imageTag}"

                            sh """#!/usr/bin/env bash
                                set -e
                                helm dependency build ../charts/${svc.chart}
                                helm upgrade --install ${svc.chart} ../charts/${svc.chart} \
                                    --namespace \"$NAMESPACE\" \
                                    --create-namespace \
                                    --reset-values \
                                    --set ${imagePath}.repository=${repository} \
                                    --set ${imagePath}.tag=${imageTag} \
                                    --wait \
                                    --timeout 5m
                            """
                        }
                    }
                }
            }
        }

        stage('Summary') {
            steps {
                echo 'developer_build job completed. Summary of service deployments:'
                script {
                    services.each { svc ->
                        def branch = env["${svc.key}_RESOLVED_BRANCH"]
                        def imageTag = env["${svc.key}_IMAGE_TAG"]
                        def repository = env["${svc.key}_IMAGE_REPOSITORY"]
                        echo "- ${svc.chart}: ${repository}:${imageTag} (branch=${branch})"
                    }
                }
            }
        }
    }
}
